/manifest.json
  Content-Type: application/json
  Access-Control-Allow-Origin: *
  Cache-Control: no-cache

/audio-bg.html
  Permissions-Policy: autoplay=*

/icon.svg
  Content-Type: image/svg+xml
  Access-Control-Allow-Origin: *

/no-image-placeholder.svg
  Content-Type: image/svg+xml
  Access-Control-Allow-Origin: *

/character-token-placeholder.png
  Content-Type: image/png
  Access-Control-Allow-Origin: *

# Non-hashed HTML and JS files — must never be cached stale
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/gm-pages/*
  Cache-Control: no-cache, no-store, must-revalidate

/audio-bg.html
  Cache-Control: no-cache, no-store, must-revalidate
  Permissions-Policy: autoplay=(self "https://www.youtube.com" "https://www.youtube-nocookie.com"), encrypted-media=(self "https://www.youtube.com" "https://www.youtube-nocookie.com"), fullscreen=(self "https://www.youtube.com" "https://www.youtube-nocookie.com"), compute-pressure=(self "https://www.youtube.com" "https://www.youtube-nocookie.com")

/audio-player.html
  Cache-Control: no-cache, no-store, must-revalidate
